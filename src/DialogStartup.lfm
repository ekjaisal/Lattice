object frmDialogStartUp: TfrmDialogStartUp
  Left = 500
  Height = 360
  Top = 250
  Width = 720
  BorderIcons = [biSystemMenu]
  BorderStyle = bsSingle
  Caption = 'Lattice'
  ClientHeight = 360
  ClientWidth = 720
  DesignTimePPI = 144
  Font.CharSet = ANSI_CHARSET
  Font.Height = -18
  Font.Name = 'Arial'
  Font.Pitch = fpVariable
  Font.Quality = fqDraft
  Position = poMainFormCenter
  LCLVersion = '4.6.0.0'
  OnCreate = FormCreate
  OnShow = FormShow
  object pnlLeft: TPanel
    Left = 0
    Height = 360
    Top = 0
    Width = 270
    Align = alLeft
    BevelOuter = bvNone
    ClientHeight = 360
    ClientWidth = 270
    Color = clWhite
    ParentBackground = False
    ParentColor = False
    TabOrder = 1
    object pbxLogo: TPaintBox
      Left = 0
      Height = 360
      Top = 0
      Width = 270
      Align = alClient
      OnPaint = pbxLogoPaint
    end
  end
  object pnlRight: TPanel
    AnchorSideLeft.Control = pnlLeft
    AnchorSideLeft.Side = asrBottom
    AnchorSideTop.Control = Owner
    AnchorSideRight.Control = Owner
    AnchorSideRight.Side = asrBottom
    AnchorSideBottom.Control = Owner
    AnchorSideBottom.Side = asrBottom
    Left = 270
    Height = 360
    Top = 0
    Width = 450
    Align = alClient
    BevelOuter = bvNone
    ClientHeight = 360
    ClientWidth = 450
    TabOrder = 0
    object pnlWelcome: TPanel
      AnchorSideLeft.Control = pnlRight
      AnchorSideTop.Control = pnlRight
      AnchorSideTop.Side = asrCenter
      AnchorSideRight.Control = pnlRight
      AnchorSideRight.Side = asrBottom
      AnchorSideBottom.Side = asrCenter
      Left = 20
      Height = 180
      Top = 90
      Width = 410
      Anchors = [akTop, akLeft, akRight]
      BorderSpacing.Left = 20
      BorderSpacing.Top = 20
      BorderSpacing.Right = 20
      BorderSpacing.Bottom = 20
      BevelOuter = bvNone
      ClientHeight = 180
      ClientWidth = 410
      TabOrder = 0
      object lblAppName: TLabel
        AnchorSideLeft.Control = pnlWelcome
        AnchorSideTop.Control = pnlWelcome
        AnchorSideRight.Control = pnlWelcome
        AnchorSideRight.Side = asrBottom
        Left = 0
        Height = 32
        Top = 0
        Width = 410
        Anchors = [akTop, akLeft, akRight]
        Caption = 'Lattice'
        Font.CharSet = ANSI_CHARSET
        Font.Height = -27
        Font.Name = 'Arial'
        Font.Pitch = fpVariable
        Font.Quality = fqDraft
        Font.Style = [fsBold]
        ParentFont = False
      end
      object lblVersion: TLabel
        AnchorSideLeft.Control = pnlWelcome
        AnchorSideTop.Control = lblAppName
        AnchorSideTop.Side = asrBottom
        AnchorSideRight.Control = pnlWelcome
        AnchorSideRight.Side = asrBottom
        Left = 0
        Height = 18
        Top = 38
        Width = 410
        Anchors = [akTop, akLeft, akRight]
        BorderSpacing.Top = 6
        Caption = 'Version'
        Font.CharSet = ANSI_CHARSET
        Font.Color = clGray
        Font.Height = -16
        Font.Name = 'Arial'
        Font.Pitch = fpVariable
        Font.Quality = fqDraft
        ParentColor = False
        ParentFont = False
      end
      object pnlAction: TPanel
        AnchorSideLeft.Control = pnlWelcome
        AnchorSideTop.Side = asrBottom
        AnchorSideRight.Control = pnlWelcome
        AnchorSideRight.Side = asrBottom
        AnchorSideBottom.Control = pnlWelcome
        AnchorSideBottom.Side = asrBottom
        Left = 0
        Height = 29
        Top = 111
        Width = 410
        Anchors = [akLeft, akRight, akBottom]
        BorderSpacing.Bottom = 40
        BevelOuter = bvNone
        ClientHeight = 29
        ClientWidth = 410
        TabOrder = 0
        object btnCreateNew: TButton
          AnchorSideLeft.Control = pnlAction
          AnchorSideTop.Control = pnlAction
          AnchorSideRight.Control = pnlWelcome
          AnchorSideRight.Side = asrBottom
          AnchorSideBottom.Control = pnlAction
          AnchorSideBottom.Side = asrBottom
          Left = 0
          Height = 29
          Top = 0
          Width = 200
          Anchors = [akTop, akLeft, akBottom]
          Caption = 'Create New Project'
          TabOrder = 0
        end
        object btnOpenExisting: TButton
