object frmDialogSort: TfrmDialogSort
  Left = 400
  Height = 290
  Top = 200
  Width = 720
  BorderIcons = [biSystemMenu]
  BorderStyle = bsSingle
  Caption = 'Sort Documents'
  ClientHeight = 290
  ClientWidth = 720
  DesignTimePPI = 144
  Font.CharSet = ANSI_CHARSET
  Font.Height = -18
  Font.Name = 'Arial'
  Font.Pitch = fpVariable
  Font.Quality = fqDraft
  Position = poMainFormCenter
  LCLVersion = '4.6.0.0'
  OnShow = FormShow
  object lblCriteria: TLabel
    AnchorSideLeft.Control = Owner
    AnchorSideTop.Control = Owner
    AnchorSideRight.Control = Owner
    AnchorSideRight.Side = asrBottom
    Left = 20
    Height = 21
    Top = 20
    Width = 680
    Anchors = [akTop, akLeft, akRight]
    BorderSpacing.Left = 20
    BorderSpacing.Top = 20
    BorderSpacing.Right = 20
    Caption = 'Sorting Criteria'
    Font.CharSet = ANSI_CHARSET
    Font.Height = -18
    Font.Name = 'Arial'
    Font.Pitch = fpVariable
    Font.Quality = fqDraft
    Font.Style = [fsBold]
    ParentFont = False
  end
  object cmbSortCriteria: TComboBox
    AnchorSideLeft.Control = Owner
    AnchorSideTop.Control = lblCriteria
    AnchorSideTop.Side = asrBottom
    AnchorSideRight.Control = Owner
    AnchorSideRight.Side = asrBottom
    Left = 20
    Height = 29
    Top = 49
    Width = 680
    Anchors = [akTop, akLeft, akRight]
    BorderSpacing.Left = 20
    BorderSpacing.Top = 8
    BorderSpacing.Right = 20
    ItemHeight = 21
    Style = csDropDownList
    TabOrder = 0
    OnChange = cmbSortCriteriaChange
  end
  object rgSortOrder: TRadioGroup
    AnchorSideLeft.Control = Owner
    AnchorSideTop.Control = cmbSortCriteria
    AnchorSideTop.Side = asrBottom
    AnchorSideRight.Control = Owner
    AnchorSideRight.Side = asrBottom
    AnchorSideBottom.Control = pnlActions
    Left = 20
    Height = 123
    Top = 98
    Width = 680
    Anchors = [akTop, akLeft, akRight, akBottom]
    AutoFill = True
    BorderSpacing.Left = 20
    BorderSpacing.Top = 20
    BorderSpacing.Right = 20
    BorderSpacing.Bottom = 20
    Caption = ' Sorting Order '
    ChildSizing.LeftRightSpacing = 10
    ChildSizing.TopBottomSpacing = 10
    ChildSizing.EnlargeHorizontal = crsHomogenousChildResize
    ChildSizing.EnlargeVertical = crsHomogenousChildResize
    ChildSizing.ShrinkHorizontal = crsScaleChilds
    ChildSizing.ShrinkVertical = crsScaleChilds
    ChildSizing.Layout = cclLeftToRightThenTopToBottom
    ChildSizing.ControlsPerLine = 1
    ClientHeight = 97
    ClientWidth = 676
    Items.Strings = (
      'Ascending'
      'Descending'
    )
    TabOrder = 1
  end
  object pnlActions: TPanel
    AnchorSideLeft.Control = Owner
    AnchorSideRight.Control = Owner
    AnchorSideRight.Side = asrBottom
    AnchorSideBottom.Control = Owner
    AnchorSideBottom.Side = asrBottom
    Left = 20
    Height = 29
    Top = 241
    Width = 680
    Anchors = [akLeft, akRight, akBottom]
    BorderSpacing.Around = 20
    BevelOuter = bvNone
    ClientHeight = 29
    ClientWidth = 680
    TabOrder = 2
    object btnSort: TButton
      AnchorSideTop.Control = pnlActions
      AnchorSideRight.Control = pnlActions
      AnchorSideRight.Side = asrBottom
      AnchorSideBottom.Control = pnlActions
      AnchorSideBottom.Side = asrBottom
      Left = 580
      Height = 29
      Top = 0
      Width = 100
      Anchors = [akTop, akRight, akBottom]
      Caption = 'Sort'
      Default = True
      ModalResult = 1
      TabOrder = 0
    end
    object btnCancel: TButton
      AnchorSideTop.Control = pnlActions
      AnchorSideRight.Control = btnSort
      AnchorSideBottom.Control = pnlActions
      AnchorSideBottom.Side = asrBottom
      Left = 470
      Height = 29
      Top = 0
      Width = 100
      Anchors = [akTop, akRight, akBottom]
      BorderSpacing.Right = 10
      Caption = 'Cancel'
      ModalResult = 2
      TabOrder = 1
    end
    object btnReset: TButton
      AnchorSideLeft.Control = pnlActions
      AnchorSideTop.Control = pnlActions
      AnchorSideBottom.Control = pnlActions
      AnchorSideBottom.Side = asrBottom
      Left = 0
      Height = 29
      Top = 0
      Width = 100
      Anchors = [akTop, akLeft, akBottom]
      Caption = 'Reset'
      TabOrder = 2
      OnClick = btnResetClick
    end
    object btnPersist: TButton
      AnchorSideTop.Control = pnlActions
      AnchorSideRight.Control = btnCancel
      AnchorSideBottom.Control = pnlActions
      AnchorSideBottom.Side = asrBottom
      Left = 230
      Height = 29
      Top = 0
      Width = 230
      Anchors = [akTop, akRight, akBottom]
      BorderSpacing.Right = 10
      Caption = 'Make Sort Permanent'
      TabOrder = 3
      OnClick = btnPersistClick
