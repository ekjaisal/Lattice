    BevelOuter = bvNone
    ClientHeight = 29
    ClientWidth = 1560
    TabOrder = 3
    object btnClearSelection: TButton
      AnchorSideLeft.Control = pnlMemoActions
      AnchorSideTop.Control = pnlMemoActions
      AnchorSideBottom.Control = pnlMemoActions
      AnchorSideBottom.Side = asrBottom
      Left = 0
      Height = 29
      Top = 0
      Width = 150
      Anchors = [akTop, akLeft, akBottom]
      Caption = 'Clear Selection'
      TabOrder = 3
