object frmModalMemo: TfrmModalMemo
  Left = 450
  Height = 850
  Top = 150
  Width = 1600
  BorderIcons = [biSystemMenu]
  Caption = 'Memo Manager'
  ClientHeight = 850
  ClientWidth = 1600
  DesignTimePPI = 144
  Font.CharSet = ANSI_CHARSET
  Font.Height = -18
  Font.Name = 'Arial'
  Font.Pitch = fpVariable
  Font.Quality = fqDraft
  Position = poMainFormCenter
  LCLVersion = '4.6.0.0'
  OnResize = FormResize
  OnShow = FormShow
  object pnlTopContainer: TPanel
    Left = 20
    Height = 49
    Top = 20
    Width = 1560
    Align = alTop
    AutoSize = True
    BorderSpacing.Left = 20
    BorderSpacing.Top = 20
    BorderSpacing.Right = 20
    BevelOuter = bvNone
    ClientHeight = 49
    ClientWidth = 1560
    TabOrder = 0
    object pnlMemoFilter: TPanel
      Left = 0
      Height = 29
      Top = 0
      Width = 1560
      Align = alTop
      BorderSpacing.Bottom = 20
      BevelOuter = bvNone
      ClientHeight = 29
      ClientWidth = 1560
      TabOrder = 0
      object cmbTypeFilter: TComboBox
        Left = 0
        Height = 29
        Top = 0
        Width = 250
        Align = alLeft
        ItemHeight = 21
        Items.Strings = (
          'All Memo Types'
          'Project Memo'
          'Document Memo'
          'Code Memo'
          'Segment Memo'
          'Analytical Memo'
        )
        Style = csDropDownList
        TabOrder = 0
        OnChange = cmbTypeFilterChange
      end
      object edtMemoSearch: TEdit
        Left = 270
        Height = 29
        Top = 0
        Width = 1290
        Align = alClient
        BorderSpacing.Left = 20
        TabOrder = 1
        TextHint = 'Search within memo titles or content'
        OnChange = edtMemoSearchChange
      end
    end
  end
  object vstMemo: TLazVirtualStringTree
    Left = 20
    Height = 500
    Top = 69
    Width = 1560
    Align = alClient
    BorderSpacing.Left = 20
    BorderSpacing.Right = 20
    BorderStyle = bsNone
    Colors.UnfocusedSelectionColor = clHighlight
    Colors.UnfocusedSelectionBorderColor = clHighlight
    DefaultNodeHeight = 29
    Header.AutoSizeIndex = -1
    Header.Columns = <    
      item
        Position = 0
        Text = 'Type'
        Width = 200
      end    
      item
        Position = 1
        Text = 'Title'
        Width = 600
      end    
      item
        Position = 2
        Text = 'Last Updated (Local Time)'
        Width = 300
      end    
      item
        Position = 3
        Text = 'References'
        Width = 460
      end>
    Header.DefaultHeight = 25
    Header.Height = 28
    Header.Options = [hoAutoResize, hoColumnResize, hoDrag, hoShowSortGlyphs, hoVisible]
    Header.ParentFont = True
    Header.SortColumn = 2
    Header.SortDirection = sdDescending
    Indent = 0
    Margin = 4
    TabOrder = 1
    TextMargin = 4
    TreeOptions.PaintOptions = [toHideFocusRect, toThemeAware, toUseBlendedImages, toUseExplorerTheme]
    TreeOptions.SelectionOptions = [toFullRowSelect, toMultiSelect]
    OnDblClick = vstMemoDblClick
    OnFocusChanged = vstMemoFocusChanged
    OnGetText = vstMemoGetText
    OnPaintText = vstMemoPaintText
    OnHeaderClick = vstMemoHeaderClick
    OnMouseDown = vstMemoMouseDown
  end
